# ===========================================
# MS Manager - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=production

# MongoDB Configuration
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your-secure-root-password
MONGO_USER=msmanager
MONGO_PASSWORD=your-secure-app-password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRE=30d

# OAuth - Google
# Get these from: https://console.developers.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Facebook
# Get these from: https://developers.facebook.com/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# URLs
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Domain and SSL
DOMAIN=your-subdomain.duckdns.org
DUCKDNS_TOKEN=replace-with-your-duckdns-token
SSL_EMAIL=you@example.com

# Public ports (host)
HTTP_PORT=80
HTTPS_PORT=443
